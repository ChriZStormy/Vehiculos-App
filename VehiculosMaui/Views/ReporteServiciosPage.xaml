<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.ReporteServiciosPage"
             Title="Reporte de Servicios">

	<ScrollView>
		<VerticalStackLayout Padding="30" Spacing="20">

			<Label Text="Vehículo:" FontAttributes="Bold" FontSize="16" TextColor="#333333" />
			<Picker Title="Seleccionar Vehículo...">
				<Picker.ItemsSource>
					<x:Array Type="{x:Type x:String}">
						<x:String>ABC123 - Nissan Sentra</x:String>
						<x:String>XY2456 - Ford F-150</x:String>
						<x:String>GHI789 - Toyota Corolla</x:String>
					</x:Array>
				</Picker.ItemsSource>
			</Picker>

			<BoxView HeightRequest="1" Color="#CCCCCC" Margin="0,10,0,10" />

			<Button Text="Ver Reporte" 
                    HeightRequest="50"
                    CornerRadius="8"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="18"/>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>