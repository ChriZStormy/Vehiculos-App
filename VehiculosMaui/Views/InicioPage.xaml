<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.InicioPage"
             Title="Inicio">

	<VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

		<Button Text="Vehículos" 
                HeightRequest="60" 
                FontSize="18"
                CornerRadius="8"
                BackgroundColor="#2196F3"
                TextColor="White"
                Clicked="OnVehiculosClicked" />

		<Button Text="Mantenimientos" 
                HeightRequest="60" 
                FontSize="18"
                CornerRadius="8"
                BackgroundColor="#2196F3"
                TextColor="White"/>

		<Button Text="Reportes de Fallas" 
                HeightRequest="60" 
                FontSize="18"
                CornerRadius="8"
                BackgroundColor="#2196F3"
                TextColor="White"/>

		<Button Text="Catálogos" 
                HeightRequest="60" 
                FontSize="18"
                CornerRadius="8"
                BackgroundColor="#2196F3"
                TextColor="White"/>

	</VerticalStackLayout>

</ContentPage>
