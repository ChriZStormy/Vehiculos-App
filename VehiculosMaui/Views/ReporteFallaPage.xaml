<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.ReporteFallaPage"
             Title="Reporte de Falla">

	<ScrollView>
		<VerticalStackLayout Padding="30" Spacing="20">

			<Label Text="Fecha:" FontAttributes="Bold" FontSize="16" TextColor="#333333" />
			<DatePicker Format="dd/MM/yyyy" />

			<Label Text="Descripción del Problema:" FontAttributes="Bold" FontSize="16" TextColor="#333333" />

			<Editor Placeholder="Describe la falla detalladamente..." 
                    HeightRequest="150" 
                    AutoSize="TextChanges" />

			<Button Text="Guardar" 
                    Margin="0,20,0,0" 
                    HeightRequest="50"
                    CornerRadius="8"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="18"/>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage> >