<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.DetalleVehiculoPage"
             Title="Detalle del Vehículo">

	<ContentPage.Background>
		<SolidColorBrush Color="#F5F7FA" />
	</ContentPage.Background>

	<ScrollView>
		<VerticalStackLayout Padding="30" Spacing="25">

			<Border StrokeShape="RoundRectangle 16" 
                    Stroke="Transparent" 
                    BackgroundColor="White" 
                    Padding="25"
                    Shadow="{Shadow Brush=Black, Offset='0,5', Opacity=0.1, Radius=10}">
				<VerticalStackLayout Spacing="15">
					<Label Text="Información del Vehículo" FontSize="22" FontAttributes="Bold" TextColor="#0D47A1" Margin="0,0,0,10"/>
					
                    <Grid ColumnDefinitions="100, *" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="15">
                        <Label Grid.Row="0" Grid.Column="0" Text="Placas:" FontSize="16" FontAttributes="Bold" TextColor="#555555" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding VehiculoSeleccionado.Placas}" FontSize="16" TextColor="#333333" />
                        
                        <Label Grid.Row="1" Grid.Column="0" Text="Marca ID:" FontSize="16" FontAttributes="Bold" TextColor="#555555" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding VehiculoSeleccionado.MarcaId}" FontSize="16" TextColor="#333333" />
                        
                        <Label Grid.Row="2" Grid.Column="0" Text="Modelo:" FontSize="16" FontAttributes="Bold" TextColor="#555555" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding VehiculoSeleccionado.Modelo}" FontSize="16" TextColor="#333333" />
                        
                        <Label Grid.Row="3" Grid.Column="0" Text="Año:" FontSize="16" FontAttributes="Bold" TextColor="#555555" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding VehiculoSeleccionado.Year}" FontSize="16" TextColor="#333333" />
                    </Grid>

				</VerticalStackLayout>
			</Border>

			<Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,20,0,0">
				<Button Grid.Column="0" 
                        Text="Editar" 
                        HeightRequest="55"
                        BackgroundColor="#1976D2" 
                        TextColor="White"
                        CornerRadius="27"
                        FontAttributes="Bold"
                        FontSize="16"
                        Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.2, Radius=5}"
                        Command="{Binding EditarCommand}" />

				<Button Grid.Column="1" 
                        Text="Eliminar" 
                        HeightRequest="55"
                        BackgroundColor="#D32F2F" 
                        TextColor="White"
                        CornerRadius="27"
                        FontAttributes="Bold"
                        FontSize="16"
                        Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.2, Radius=5}"
                        Command="{Binding EliminarCommand}" />
			</Grid>
		</VerticalStackLayout>
	</ScrollView>

</ContentPage>