<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.DetalleVehiculoPage"
             Title="Detalle del Vehículo">

	<ScrollView>
		<VerticalStackLayout Padding="30" Spacing="20">

			<Frame BorderColor="LightGray" CornerRadius="8" Padding="20" HasShadow="False">
				<VerticalStackLayout Spacing="15">
					<Label Text="{Binding VehiculoSeleccionado.Placas, StringFormat='Placas: {0}'}" FontSize="18" TextColor="#333333" />
					<Label Text="{Binding VehiculoSeleccionado.MarcaId, StringFormat='Marca ID: {0}'}" FontSize="18" TextColor="#333333" />
					<Label Text="{Binding VehiculoSeleccionado.Modelo, StringFormat='Modelo: {0}'}" FontSize="18" TextColor="#333333" />
					<Label Text="{Binding VehiculoSeleccionado.Year, StringFormat='Año: {0}'}" FontSize="18" TextColor="#333333" />
				</VerticalStackLayout>
			</Frame>

			<Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,20,0,0">

				<Button Grid.Column="0" 
                        Text="Editar" 
                        HeightRequest="50"
                        BackgroundColor="#2196F3" 
                        TextColor="White"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        Command="{Binding EditarCommand}" />

				<Button Grid.Column="1" 
                        Text="Eliminar" 
                        HeightRequest="50"
                        BackgroundColor="#f44336" 
                        TextColor="White"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        Command="{Binding EliminarCommand}" />

			</Grid>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>