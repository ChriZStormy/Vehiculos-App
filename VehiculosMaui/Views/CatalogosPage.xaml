<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.CatalogosPage"
             Title="Catálogos">

	<VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

		<Button Text="Tipos de Vehículo" 
                HeightRequest="60" 
                FontSize="18"
                CornerRadius="8"
                BackgroundColor="#2196F3"
                TextColor="White"
                FontAttributes="Bold"/>

		<Button Text="Tipos de Servicio" 
                HeightRequest="60" 
                FontSize="18"
                CornerRadius="8"
                BackgroundColor="#2196F3"
                TextColor="White"
                FontAttributes="Bold"/>

		<Button Text="Estados del Vehículo" 
                HeightRequest="60" 
                FontSize="18"
                CornerRadius="8"
                BackgroundColor="#2196F3"
                TextColor="White"
                FontAttributes="Bold"/>

	</VerticalStackLayout>

</ContentPage>