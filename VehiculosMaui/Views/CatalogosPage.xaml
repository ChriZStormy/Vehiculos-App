<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:VehiculosMaui.ViewModels"
             x:Class="VehiculosMaui.Views.CatalogosPage"
             Title="Catálogos">

	<ContentPage.BindingContext>
		<viewmodels:CatalogosViewModel />
	</ContentPage.BindingContext>

	<ContentPage.Background>
		<SolidColorBrush Color="#F5F7FA" />
	</ContentPage.Background>

	<Grid RowDefinitions="Auto, *">
		<VerticalStackLayout Padding="20" Spacing="15" Grid.Row="0">
			<Label Text="Marcas de Vehículos" FontSize="22" FontAttributes="Bold" TextColor="#0D47A1" Margin="0,0,0,10" HorizontalOptions="Center"/>
		</VerticalStackLayout>

		<CollectionView ItemsSource="{Binding Marcas}" Grid.Row="1" Margin="20,0,20,0">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Border StrokeShape="RoundRectangle 12" 
                            Stroke="Transparent" 
                            BackgroundColor="White" 
                            Padding="20"
                            Margin="0,0,0,15"
                            Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.1, Radius=4}">
						<Grid ColumnDefinitions="Auto, *" VerticalOptions="Center">
							<Label Grid.Column="0" Text="{Binding Id}" FontSize="16" FontAttributes="Bold" TextColor="#555555" Margin="0,0,15,0"/>
							<Label Grid.Column="1" Text="{Binding marca}" FontSize="18" FontAttributes="Bold" TextColor="#0D47A1" />
						</Grid>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>
	</Grid>

</ContentPage>