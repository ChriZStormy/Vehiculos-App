<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:VehiculosMaui.ViewModels"
             x:Class="VehiculosMaui.Views.RegistrarVehiculoPage"
             Title="Registrar Vehículo">

	<ContentPage.BindingContext>
		<viewmodels:RegistrarVehiculoViewModel />
	</ContentPage.BindingContext>

	<ScrollView>
		<VerticalStackLayout Padding="30" Spacing="20">

			<Entry Placeholder="Modelo (ej. Corolla)" 
                   Text="{Binding Modelo}" />

			<Entry Placeholder="Año (ej. 2024)" 
                   Text="{Binding Year}" 
                   Keyboard="Numeric" />
			<Entry Placeholder="Placas" 
                   Text="{Binding Placas}" />

			<Entry Placeholder="ID de la Marca" 
                   Text="{Binding MarcaId}" 
                   Keyboard="Numeric" />

			<Button Text="Guardar Vehículo" 
                    Command="{Binding GuardarCommand}"
                    HeightRequest="50"
                    CornerRadius="8"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    Margin="0,20,0,0"/>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>