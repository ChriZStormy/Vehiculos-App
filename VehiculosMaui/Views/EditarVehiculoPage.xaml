<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:VehiculosMaui.ViewModels"
             x:Class="VehiculosMaui.Views.EditarVehiculoPage"
             Title="Editar Vehículo">

	<ContentPage.BindingContext>
		<viewmodels:EditarVehiculoViewModel />
	</ContentPage.BindingContext>

	<ContentPage.Background>
		<SolidColorBrush Color="#F5F7FA" />
	</ContentPage.Background>

	<ScrollView>
		<VerticalStackLayout Padding="30" Spacing="25">

            <Label Text="Actualizar Datos" FontSize="22" FontAttributes="Bold" TextColor="#0D47A1" Margin="0,0,0,10"/>

			<Border StrokeShape="RoundRectangle 12" Stroke="Transparent" BackgroundColor="White" Padding="20" Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.1, Radius=5}">
				<VerticalStackLayout Spacing="15">
					<Label Text="Modelo" FontSize="14" FontAttributes="Bold" TextColor="#555555" />
					<Entry Placeholder="ej. Corolla" Text="{Binding Modelo}" BackgroundColor="#F5F7FA" />

					<Label Text="Año" FontSize="14" FontAttributes="Bold" TextColor="#555555" />
					<Entry Placeholder="ej. 2024" Text="{Binding Year}" Keyboard="Numeric" BackgroundColor="#F5F7FA" />

					<Label Text="Placas" FontSize="14" FontAttributes="Bold" TextColor="#555555" />
					<Entry Placeholder="ej. ABC-123" Text="{Binding Placas}" BackgroundColor="#F5F7FA" />

					<Label Text="ID de Marca" FontSize="14" FontAttributes="Bold" TextColor="#555555" />
					<Entry Placeholder="ej. 1" Text="{Binding MarcaId}" Keyboard="Numeric" BackgroundColor="#F5F7FA" />
				</VerticalStackLayout>
			</Border>

			<Button Text="Actualizar Vehículo" 
                    Command="{Binding GuardarCommand}"
                    HeightRequest="55"
                    CornerRadius="27"
                    BackgroundColor="#0D47A1"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    Margin="0,15,0,0"
                    Shadow="{Shadow Brush=Black, Offset='0,5', Opacity=0.3, Radius=5}"/>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>
