<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.ListaVehiculosPage"
             Title="Lista de Vehículos">

	<ContentPage.Background>
		<SolidColorBrush Color="#F5F7FA" />
	</ContentPage.Background>

	<Grid RowDefinitions="Auto, *, Auto">
		<VerticalStackLayout Padding="20" Spacing="15" Grid.Row="0">
			<SearchBar Placeholder="Buscar vehículo..." 
                       CancelButtonColor="Red" 
                       BackgroundColor="White"/>
		</VerticalStackLayout>

		<CollectionView ItemsSource="{Binding Vehiculos}" Grid.Row="1" Margin="20,0,20,0">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Border StrokeShape="RoundRectangle 12" 
                            Stroke="Transparent" 
                            BackgroundColor="White" 
                            Padding="15"
                            Margin="0,0,0,15"
                            Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.1, Radius=4}">
						<Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
							<VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="5">
								<Label Text="{Binding Placas, StringFormat='Placas: {0}'}" 
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       TextColor="#0D47A1" />
								<Label Text="{Binding Modelo, StringFormat='Modelo: {0}'}" 
                                       FontSize="14" 
                                       TextColor="#333333" />
								<Label Text="{Binding Year, StringFormat='Año: {0}'}" 
                                       FontSize="14" 
                                       TextColor="#666666" />
							</VerticalStackLayout>

							<Button Grid.Column="1" 
                                    Text="Detalle" 
                                    HeightRequest="40" 
                                    Padding="15,0" 
                                    BackgroundColor="#1976D2" 
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="20"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VerDetalleCommand}"
                                    CommandParameter="{Binding .}" />
						</Grid>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<Button Grid.Row="2" 
                Text="+ Registrar Nuevo Vehículo" 
                Command="{Binding RegistrarNuevoCommand}"
                Margin="20"
                HeightRequest="55"
                CornerRadius="27"
                BackgroundColor="#0D47A1"
                TextColor="White"
                FontAttributes="Bold"
                FontSize="16"
                Shadow="{Shadow Brush=Black, Offset='0,5', Opacity=0.3, Radius=5}" />
	</Grid>

</ContentPage>