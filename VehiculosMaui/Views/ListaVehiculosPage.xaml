<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.ListaVehiculosPage"
             Title="Lista de Vehículos">

	<Grid RowDefinitions="Auto, *">
		<VerticalStackLayout Padding="20" Spacing="15" Grid.Row="0">
			<SearchBar Placeholder="Buscar..." 
                       CancelButtonColor="Red" />
		</VerticalStackLayout>

		<CollectionView ItemsSource="{Binding Vehiculos}" Grid.Row="1" Margin="20,0,20,20">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Border StrokeShape="RoundRectangle 8" 
                            Stroke="#CCCCCC" 
                            BackgroundColor="White" 
                            Padding="15"
                            Margin="0,0,0,15">
						<Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
							<VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
								<Label Text="{Binding Placas, StringFormat='{0}'}" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="#333333" />
								<Label Text="{Binding Modelo, StringFormat='Modelo: {0}'}" 
                                       FontSize="14" 
                                       TextColor="#666666" />
								<Label Text="{Binding Year, StringFormat='Año: {0}'}" 
                                       FontSize="14" 
                                       TextColor="#666666" />
							</VerticalStackLayout>

							<Button Grid.Column="1" 
                                    Text="Ver Detalle" 
                                    HeightRequest="35" 
                                    Padding="10,0" 
                                    BackgroundColor="#2196F3" 
                                    TextColor="White"
                                    CornerRadius="5"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VerDetalleCommand}"
                                    CommandParameter="{Binding .}" />
						</Grid>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>
	</Grid>

</ContentPage>